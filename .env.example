# ----------------------------------------------------
# Database Configuration (PostgreSQL)
# ----------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=srilaxmi
DB_HOST=db
DB_PORT=5432
# Alternatively, specify a unified connection string (RDS, etc.)
# DATABASE_URL=postgresql://postgres:postgres@db:5432/srilaxmi

# ----------------------------------------------------
# Security Configuration
# ----------------------------------------------------
# API Key protecting GDPR export and deletion endpoints
ADMIN_API_KEY=srilaxmi_admin_secret_key

# ----------------------------------------------------
# AWS Configuration (S3 Uploads, S3 Backups, SES)
# ----------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=eu-west-1
S3_UPLOAD_BUCKET=your-srilaxmi-enquiry-uploads
S3_BACKUP_BUCKET=your-srilaxmi-db-backups

# AWS SES verified sender and receiver emails
SES_FROM_EMAIL=info@srilaxmiengineering.com
SES_TO_EMAIL=sales@srilaxmiengineering.com

# ----------------------------------------------------
# Monitoring Configuration (Datadog)
# ----------------------------------------------------
DATADOG_API_KEY=your_datadog_api_key
